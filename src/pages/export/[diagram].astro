---
/**
 * Diagram export surface (DEV ONLY)
 *
 * A chrome-less, theme-pinned page that renders ONE SDK diagram on a solid
 * background, sized to an arbitrary output frame, for screenshotting into a
 * static figure that travels to platforms which can't run the live page
 * (LinkedIn, Substack, X). Not the article — just the figure, on a
 * controlled surface, so it reads as a designed image rather than a
 * screenshot of the site.
 *
 * Diagrams are addressed by their registry id; stepped diagrams take a
 * `step` and render that step's scene with a static chip strip above it,
 * so an assembled GIF carries its own progress indicator.
 *
 *   /export/ledger?w=1200
 *   /export/pipeline-agentic?w=1600&theme=steel
 *   /export/migration?step=3            (chip strip marks the active step)
 *   /export/verify-loop?w=1200&h=630    (card: exact 1200×630, centred)
 *
 * Params: w (output width px), pad (uniform margin px), h (OPTIONAL — when
 * given, makes an exact w×h card with the diagram contained and centred;
 * when omitted, the frame wraps the diagram tightly with uniform padding),
 * theme (pinned palette, default charcoal), step (stepped diagrams only).
 * Device pixel ratio is the screenshot tool's job (Playwright
 * deviceScaleFactor), not a param.
 *
 * Returns 404 in production — run it against `npm run dev` + Playwright.
 */
import "../../styles/global.css";

import {renderDiagram} from "../../lib/diagrams";
import type {DiagramDef, Scene, SteppedDiagramDef} from "../../lib/diagrams";
import {
  agenticPipeline,
  ledger,
  migration,
  oneShotPipeline,
  verifyLoop,
} from "../../diagrams";

export const prerender = false;

const STATIC_DIAGRAMS: Record<string, DiagramDef> = Object.fromEntries(
  [agenticPipeline, ledger, oneShotPipeline, verifyLoop].map((def) => [
    def.id,
    def,
  ])
);
const STEPPED_DIAGRAMS: Record<string, SteppedDiagramDef> = Object.fromEntries(
  [migration].map((def) => [def.id, def])
);

const {diagram} = Astro.params;

if (
  import.meta.env.PROD ||
  !diagram ||
  !(diagram in STATIC_DIAGRAMS || diagram in STEPPED_DIAGRAMS)
) {
  return new Response("Not found", {status: 404});
}

const q = Astro.url.searchParams;
const clampInt = (v: number, min: number, max: number): number =>
  Math.min(max, Math.max(min, Math.round(v)));
const num = (key: string, fallback: number): number => {
  const raw = q.get(key);
  if (raw === null || raw.trim() === "") {
    return fallback;
  }
  const v = Number(raw);
  return Number.isFinite(v) ? v : fallback;
};

const w = clampInt(num("w", 1200), 16, 4096);
const pad = clampInt(num("pad", 64), 0, 1024);
const theme = q.get("theme") ?? "charcoal";

// Resolve the definition: a static diagram renders as-is; a stepped one
// renders the requested step's scene (base + step) as a one-off static
// definition, with the chip strip carrying the step state.
const stepped = STEPPED_DIAGRAMS[diagram];
const step = stepped
  ? clampInt(num("step", 0), 0, stepped.steps.length - 1)
  : 0;
const def: DiagramDef = stepped
  ? {
      id: stepped.id,
      size: stepped.size,
      ariaLabel: stepped.ariaLabel,
      scene: (d: Scene) => {
        stepped.base?.(d);
        stepped.steps[step]?.scene(d);
      },
    }
  : (STATIC_DIAGRAMS[diagram] as DiagramDef);

const svg = renderDiagram(def);
const [logicalW, logicalH] = def.size;
const ar = logicalW / logicalH;

// An explicit `h` switches to fixed-card mode: the diagram is contained and
// centred in an exact w×h frame. With no `h`, the frame wraps the diagram
// tightly with uniform padding.
const hRaw = q.get("h");
const h =
  hRaw !== null && hRaw.trim() !== "" && Number.isFinite(Number(hRaw))
    ? clampInt(Number(hRaw), 16, 4096)
    : null;

let cw: number;
if (h !== null) {
  const availW = Math.max(1, w - 2 * pad);
  const availH = Math.max(1, h - 2 * pad);
  cw = availW;
  if (cw / ar > availH) {
    cw = availH * ar;
  }
} else {
  cw = Math.max(1, w - 2 * pad);
}

const frameStyle =
  h !== null
    ? `width:${w}px;height:${h}px`
    : stepped
      ? `width:${w}px;padding:${pad}px`
      : `width:${w}px;height:${Math.round(cw / ar + 2 * pad)}px`;
---

<!doctype html>
<html lang="en" class={`theme-${theme}`}>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>export · {diagram}</title>
    <link
      rel="preload"
      href="/fonts/Switzer-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/CommitMono-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
      }

      /* The dev toolbar would otherwise leak into export screenshots. */
      astro-dev-toolbar {
        display: none;
      }

      .export-frame {
        background: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .export-frame svg {
        display: block;
        height: auto;
        width: 100%;
      }

      /* Stepped exports stack a static chip strip above the scene, sized up
         to sit alongside the scaled figure, so an assembled GIF carries its
         own progress indicator. */
      .export-stepped {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .export-tabs {
        display: grid;
        grid-template-columns: repeat(var(--export-steps, 7), 1fr);
        gap: 8px;
      }

      .export-tab {
        display: flex;
        justify-content: center;
        align-items: baseline;
        gap: 8px;
        padding: 16px;
        font-family: var(--font-sans);
        font-size: 28px;
        color: var(--muted);
        border: 1px solid var(--rule);
        border-radius: 8px;
      }

      .export-tab-index {
        font-family: var(--font-mono);
        font-size: 20px;
        color: var(--muted);
      }

      .export-tab.is-active {
        color: var(--emphasis);
        border-color: var(--fg);
      }

      .export-tab.is-active .export-tab-index {
        color: var(--emphasis);
      }
    </style>
  </head>
  <body>
    <div class="export-frame" style={frameStyle}>
      {
        stepped ? (
          <div
            class="export-stepped"
            style={`width:${Math.round(cw)}px;--export-steps:${stepped.steps.length}`}
          >
            <div class="export-tabs">
              {stepped.steps.map((s, i) => (
                <div class={`export-tab${i === step ? " is-active" : ""}`}>
                  <span class="export-tab-index">{i + 1}</span>
                  <span class="export-tab-label">{s.tab}</span>
                </div>
              ))}
            </div>
            <Fragment set:html={svg} />
          </div>
        ) : (
          <div style={`width:${Math.round(cw)}px`}>
            <Fragment set:html={svg} />
          </div>
        )
      }
    </div>
  </body>
</html>
