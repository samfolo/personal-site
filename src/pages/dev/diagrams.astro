---
/**
 * Diagram SDK preview (DEV ONLY)
 *
 * A plain article-width surface rendering every registered SDK diagram, for
 * composing and iterating without touching a post. Returns 404 in
 * production.
 *
 *   /dev/diagrams                theme-steel, no grid
 *   /dev/diagrams?theme=teal     pin any theme class
 *   /dev/diagrams?grid=1         overlay the module grid on every figure
 */
import {ComparedDiagram, Diagram, SteppedDiagram} from "../../components/blog";
import {
  agenticPipeline,
  ledger,
  migration,
  oneShotPipeline,
  verifyLoop,
} from "../../diagrams";
import "../../styles/global.css";

export const prerender = false;

if (import.meta.env.PROD) {
  return new Response("Not found", {status: 404});
}

const query = Astro.url.searchParams;
const theme = query.get("theme") ?? "steel";
const debugGrid = query.get("grid") === "1";
---

<html lang="en-GB" class={`theme-${theme}`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>diagrams · dev</title>
  </head>
  <body>
    <main>
      <h1>Diagram SDK preview</h1>

      <Diagram
        of={ledger}
        caption="A simplified vignette of the billing engine – a credit lot and the entries that consume it. The remainder is derived, never stored, so it can't drift."
        debugGrid={debugGrid}
      >
        <Fragment slot="description">
          Two database records side by side: a credit lot with an immutable
          nanodollar amount, and the signed ledger entries that consume it, one
          lot to many entries. The remaining balance sits below the entries,
          dashed and badged as derived – the sum of the lot's signed entries,
          never stored.
        </Fragment>
      </Diagram>

      <Diagram
        of={verifyLoop}
        caption="The main thread hands off to a separate verifier; a pass commits, a fail returns the critique to the thread."
        debugGrid={debugGrid}
      >
        <Fragment slot="description">
          The main thread runs a sequence of steps – search, read, reason,
          submit. Submitting hands off to a separate verifier thread that
          reviews the proposed result: a pass commits the result to the
          knowledge graph; a fail returns the critique to the main thread, which
          tries again.
        </Fragment>
      </Diagram>

      <ComparedDiagram
        id="ingestion-pipelines"
        caption="Ingestion, one-shot versus agentic – and what each costs."
        debugGrid={debugGrid}
        views={[
          {
            tab: "One-shot",
            of: oneShotPipeline,
            note: "Triage still fans out to one task per candidate – but each stage is a single call, so the bill stays close to the number of candidates.",
          },
          {
            tab: "Agentic",
            of: agenticPipeline,
            note: "The same fan-out – but each triage and relate unit is a durable thread: a loop of up to 25 turns, then a verifier (up to 2 tries). That is where the order-of-magnitude more inference goes.",
          },
        ]}
      >
        <Fragment slot="description">
          Two views of the ingestion pipeline, selectable with a one-shot /
          agentic tab. Both share the same shape: text enters an extract stage,
          which fans out to one triage task per candidate claim; the tasks
          converge on a single relate stage before the knowledge graph. In the
          one-shot view each stage is a single model call, so for six candidates
          the run is roughly eight calls. In the agentic view each triage and
          relate unit is instead a durable thread – a tool-using loop of up to
          25 turns followed by a fresh-context verifier of up to two tries –
          which is where the order-of-magnitude increase in inference goes.
        </Fragment>
      </ComparedDiagram>

      <SteppedDiagram of={migration} debugGrid={debugGrid}>
        <Fragment slot="description">
          A seven-step diagram of a zero-downtime embedding migration.
          Throughout, reads and writes are served by the active profile —
          profile A, the older model text-embedding-3-small at 768 dimensions —
          while a background reindex worker fills a new profile, profile B, the
          newer model embeddinggemma; the system never dual-writes. The steps:
          (1) Steady state — one active profile serves every read and write. (2)
          Kickoff — an empty new profile B is created. (3) List — the worker
          enumerates the items that do not yet have a B-embedding. (4) Backfill
          — the worker re-embeds the corpus into B, while new writes keep
          landing only in A and so keep reappearing on the worker's list, a
          target that moves as the system is used. (5) Index — B's search index
          is built. (6) Reconcile and flip — under a brief lock the last
          in-flight writes drain, any stragglers are embedded, and the new
          profile is marked finished. (7) After — that single state change makes
          B live; reads were never interrupted and the old profile is later
          retired.
        </Fragment>
      </SteppedDiagram>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--bg);
    font-family: var(--font-sans);
  }

  main {
    max-width: 45rem;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5);
  }

  h1 {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-labels);
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 var(--space-6);
  }
</style>
