---
/**
 * MigrationWalkthrough
 *
 * Stepped canvas schematic of a zero-downtime embedding migration. A CSS-only
 * segmented control (radio-driven, no client JavaScript for state) selects the
 * phase; the canvas redraws and the per-phase title and blurb (the figure's
 * caption) update. Rendering and the phase copy live in
 * scripts/diagrams/migration.ts.
 *
 * Self-contained: takes no props. The content is specific to this article.
 */

const STEPS = [
  "Steady",
  "Kickoff",
  "List",
  "Backfill",
  "Index",
  "Flip",
  "After",
];

const INITIAL_TITLE = "Steady state";
const INITIAL_BLURB =
  "One profile, <code>A</code>, holds every embedding. Searches read from it and new writes land in it. The migration has to keep this working the whole way through.";
---

<figure class="not-prose diagram-figure" aria-labelledby="migration-caption">
  <div class="migration__steps">
    {
      STEPS.map((_, i) => (
        <input
          class="migration__radio"
          type="radio"
          name="migration-step"
          id={`mig-${i}`}
          data-step={i}
          checked={i === 0}
        />
      ))
    }

    <div class="migration__tabs" role="presentation">
      {
        STEPS.map((label, i) => (
          <label class="migration__tab" for={`mig-${i}`}>
            <span class="migration__tab-index">{i + 1}</span>
            <span class="migration__tab-label">{label}</span>
          </label>
        ))
      }
    </div>
  </div>

  <canvas
    class="migration__canvas"
    data-diagram="migration"
    role="img"
    aria-label="Zero-downtime embedding migration: a seven-step walkthrough."
    aria-describedby="migration-diagram-desc"
  ></canvas>

  <figcaption id="migration-caption" class="migration__caption">
    <p class="migration__title" data-step-title set:html={INITIAL_TITLE} />
    <p class="diagram-caption migration__note" data-step-note set:html={INITIAL_BLURB} />
  </figcaption>

  <div class="diagram-desc" id="migration-diagram-desc">
    A seven-step diagram of a zero-downtime embedding migration. Throughout,
    reads and writes are served by the active profile — profile A, the older
    model text-embedding-3-small at 768 dimensions — while a background reindex
    worker fills a new profile, profile B, the newer model embeddinggemma; the
    system never dual-writes. The steps: (1) Steady state — one active profile
    serves every read and write. (2) Kickoff — an empty new profile B is
    created. (3) List — the worker enumerates the items that do not yet have a
    B-embedding. (4) Backfill — the worker re-embeds the corpus into B, while
    new writes keep landing only in A and so keep reappearing on the worker's
    list, a target that moves as the system is used. (5) Index — B's search
    index is built. (6) Reconcile and flip — under a brief lock the last
    in-flight writes drain, any stragglers are embedded, and the new profile is
    marked finished. (7) After — because the active profile is derived as the
    most recent finished profile, that single state change makes B live; reads
    were never interrupted and the old profile is later retired. Reads never
    pause; writes pause only momentarily during the final flip.
  </div>
</figure>

<script src="../../scripts/diagrams/migration.ts"></script>

<style>
  /* Radios drive the stepper; kept focusable, removed from layout. */
  .migration__radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .migration__tabs {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-1);
  }

  .migration__tab {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: var(--space-1);
    min-width: 0;
    cursor: pointer;
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-body);
    color: var(--muted);
    border: var(--border-hairline) solid var(--rule);
    border-radius: var(--space-1);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .migration__tab-index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .migration__tab-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .migration__tab:hover {
    color: var(--fg);
  }

  #mig-0:checked ~ .migration__tabs .migration__tab[for="mig-0"],
  #mig-1:checked ~ .migration__tabs .migration__tab[for="mig-1"],
  #mig-2:checked ~ .migration__tabs .migration__tab[for="mig-2"],
  #mig-3:checked ~ .migration__tabs .migration__tab[for="mig-3"],
  #mig-4:checked ~ .migration__tabs .migration__tab[for="mig-4"],
  #mig-5:checked ~ .migration__tabs .migration__tab[for="mig-5"],
  #mig-6:checked ~ .migration__tabs .migration__tab[for="mig-6"] {
    color: var(--emphasis);
    border-color: var(--fg);
  }

  #mig-0:checked ~ .migration__tabs .migration__tab[for="mig-0"] .migration__tab-index,
  #mig-1:checked ~ .migration__tabs .migration__tab[for="mig-1"] .migration__tab-index,
  #mig-2:checked ~ .migration__tabs .migration__tab[for="mig-2"] .migration__tab-index,
  #mig-3:checked ~ .migration__tabs .migration__tab[for="mig-3"] .migration__tab-index,
  #mig-4:checked ~ .migration__tabs .migration__tab[for="mig-4"] .migration__tab-index,
  #mig-5:checked ~ .migration__tabs .migration__tab[for="mig-5"] .migration__tab-index,
  #mig-6:checked ~ .migration__tabs .migration__tab[for="mig-6"] .migration__tab-index {
    color: var(--emphasis);
  }

  #mig-0:focus-visible ~ .migration__tabs .migration__tab[for="mig-0"],
  #mig-1:focus-visible ~ .migration__tabs .migration__tab[for="mig-1"],
  #mig-2:focus-visible ~ .migration__tabs .migration__tab[for="mig-2"],
  #mig-3:focus-visible ~ .migration__tabs .migration__tab[for="mig-3"],
  #mig-4:focus-visible ~ .migration__tabs .migration__tab[for="mig-4"],
  #mig-5:focus-visible ~ .migration__tabs .migration__tab[for="mig-5"],
  #mig-6:focus-visible ~ .migration__tabs .migration__tab[for="mig-6"] {
    outline: var(--outline-width) solid var(--highlight);
    outline-offset: var(--outline-offset-tight);
  }

  .migration__canvas {
    display: block;
    width: 100%;
    aspect-ratio: 672 / 320;
    margin-top: var(--space-4);
  }

  .migration__caption {
    margin-top: var(--space-4);
    min-height: 4rem;
  }

  .migration__title {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--emphasis);
    margin: 0 0 var(--space-1);
  }

  .migration__note {
    margin: 0;
  }

  .migration__caption :global(code) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: var(--space-05) var(--space-1);
    border-radius: var(--space-1);
    background: var(--rule);
    color: var(--fg);
  }

  @media (prefers-reduced-motion: reduce) {
    .migration__tab {
      transition: none;
    }
  }
</style>
