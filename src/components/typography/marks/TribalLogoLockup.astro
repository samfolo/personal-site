---
/**
 * TribalLogoLockup Component
 *
 * Inline brand mark for Tribal, rendered as an SVG link.
 * Inherits foreground colour, transitions to emphasis on hover.
 * Sized to match body text font-size for seamless inline flow.
 *
 * @example
 * <p>Building <TribalLogoLockup />, semantic memory served over MCP.</p>
 */

import type {HTMLAttributes} from "astro/types";

/**
 * Props for the TribalLogoLockup component.
 */
interface Props extends Omit<HTMLAttributes<"a">, "href"> {}

const {class: className, ...attrs} = Astro.props;
